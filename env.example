# Copy this file to .env.local and fill in your values


# Google Sheets - REQUIRED for add/edit/view claims
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable Google Sheets API and share your spreadsheet with the service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-spreadsheet-id-from-url
